{
  "framework": "sveltekit",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "headers": [
    {
      "source": "/photography/_app/immutable/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/",
      "destination": "https://ninochavez.co/photography",
      "permanent": true
    },
    {
      "source": "/photo/:path*",
      "destination": "/photography/photo/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/robots.txt",
      "destination": "/photography/robots.txt"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/photography/sitemap.xml"
    }
  ]
}
