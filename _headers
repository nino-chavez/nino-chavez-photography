# Long-lived caching for content-stable static assets served under the
# /photography base path. Without this, Cloudflare Pages applies its default
# `max-age=0, must-revalidate` to non-hashed static files, forcing a
# revalidation round-trip on every visit — including the LCP hero image.
#
# adapter-cloudflare appends its autogenerated `/photography/_app/immutable/*`
# block to this file at build time; both coexist in the deployed _headers.

# Images (hero + other static imagery). SWR rather than `immutable` so a
# re-uploaded image under the same filename still propagates within a day.
/photography/images/*
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

# Fonts are truly immutable (content never changes for a given file).
/photography/fonts/*
  Cache-Control: public, max-age=31536000, immutable
